{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.22/MicrosoftTeams.schema.json",
  "manifestVersion": "1.22",
  "version": "1.0.0",
  "id": "__CLIENT_ID__",
  "developer": {
    "name": "MMC CTSS Knowledge team",
    "websiteUrl": "https://__VALID_DOMAIN__",
    "privacyUrl": "https://__VALID_DOMAIN__/privacy",
    "termsOfUseUrl": "https://__VALID_DOMAIN__/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "KB Assistant",
    "full": "KB Knowledge Assistant"
  },
  "description": {
    "short": "Ask about KB articles, flagging, feedback, and the CTSS knowledge workflow.",
    "full": "Grounded assistant that answers MMC colleague questions about KB0022991 (flagging/lifecycle) and KB0020882 (article creation) with verifiable citations. Every answer opens the source panel to the exact cited section."
  },
  "accentColor": "#1f2937",
  "configurableTabs": [],
  "staticTabs": [
    {
      "entityId": "kb-assistant",
      "name": "KB Assistant",
      "contentUrl": "__CONTENT_URL__",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["__VALID_DOMAIN__"],
  "webApplicationInfo": {
    "id": "__CLIENT_ID__",
    "resource": "__RESOURCE__",
    "nestedAppAuthInfo": [
      {
        "redirectUri": "__REDIRECT_URI__",
        "scopes": ["openid", "profile", "email"]
      }
    ]
  }
}
