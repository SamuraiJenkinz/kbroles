# .env.example — local dev template for KB Assistant
#
# Copy to .env.local and set LLM_API_KEY. Everything else has sensible dev
# defaults in src/config/env.ts — you can leave the rest unset for local
# development. Auth is stubbed in dev mode (NODE_ENV !== 'production'), so
# you do not need real Entra credentials to run `pnpm dev` or tests.
#
# For production, secrets live in AWS Secrets Manager at /mmc/cts/kb-assistant
# and are loaded via src/auth/loadSecrets.ts at server start. Do NOT put
# production values in a .env file. See docs/env-handling.md for the full
# cascade (AWS Secrets Manager → loadSecrets() → process.env).
#
# Authoritative env schema: src/config/env.ts (zod).

# ─────────────────────────────────────────────────────────────
# LLM — required for dev
# ─────────────────────────────────────────────────────────────

# Dev: direct OpenAI (Bearer auth). Replace LLM_API_KEY with a real key.
LLM_AUTH_MODE=bearer
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=gpt-4o-2024-08-06

# Production (MGTI corporate ingress) — values come from AWS Secrets Manager
# at runtime, NOT from .env files. Shown here for reference only.
# LLM_AUTH_MODE=api-key
# LLM_BASE_URL=https://stg1.mmc-dallas-int-non-prod-ingress.mgti.mmc.com/coreapi/openai/v1
# LLM_API_KEY=<MGTI-issued key>
# LLM_MODEL=<MGTI deployment name for gpt-4o>

# Strict JSON Schema response_format capability flag. Default 'true'.
# Flip to 'false' ONLY if the MGTI deployment rejects strict mode and the
# Ajv-validated json_object fallback path must be used. See
# .planning/phases/01-grounding-foundation/05-phase0-smoke-PLAN.md.
# STRICT_SCHEMA_SUPPORTED=true

# MMC corporate CA bundle for outbound HTTPS. MUST be set in the shell
# environment before `node` starts (Scheduled Task env var, Docker ENV, or
# `export`). Node reads this at TLS init — BEFORE dotenv runs — so setting
# it in a .env file has no effect. See nodejs/node#51426.
# NODE_EXTRA_CA_CERTS=C:\path\to\mmc-corporate-ca-bundle.pem

# ─────────────────────────────────────────────────────────────
# App config — optional, sensible defaults
# ─────────────────────────────────────────────────────────────

# Named mailbox the "Flag this gap" fallback affordance addresses. Placeholder
# default is fine for dev; operator fills the real mailbox before pilot day 1.
# CONTENT_STEWARD_EMAIL=kb-knowledge-team@mmc.com

# ─────────────────────────────────────────────────────────────
# Entra ID (BFF pattern — server-only, Phase 5.1)
# ─────────────────────────────────────────────────────────────
#
# All five are server-only. No NEXT_PUBLIC_* — nothing Entra-related reaches
# the browser bundle. Dev defaults 'dev-only-do-not-use-in-prod' let Phase
# 2/3/4 tests run without Entra wiring.
#
# In production, these come from AWS Secrets Manager:
#   ENTRA_CLIENT_ID   → plain env var (not a secret — public client ID)
#   ENTRA_TENANT_ID   → plain env var
#   ENTRA_CLIENT_SECRET → AWS Secrets Manager (confidential-client secret)
#   SESSION_SECRET    → AWS Secrets Manager (iron-session AES-256-GCM key)
#   APP_BASE_URL      → env var per deploy target; MUST match Entra redirect
#                       URI exactly or AADSTS50011 fires (Pitfall 4)
#
# See docs/entra-app-registration-setup.md for the Entra side.

# ENTRA_CLIENT_ID=<client-id-guid>
# ENTRA_TENANT_ID=<tenant-id-guid>
# ENTRA_CLIENT_SECRET=<from-AWS-Secrets-Manager>
# SESSION_SECRET=<32-plus-random-bytes-from-AWS-Secrets-Manager>
# APP_BASE_URL=https://your-host.mmc.com

# ─────────────────────────────────────────────────────────────
# AWS Secrets Manager (production)
# ─────────────────────────────────────────────────────────────
#
# loadSecrets() uses the default AWS SDK credential chain (IAM role,
# environment, shared config, etc.). In dev it's skipped — env wins. See
# docs/env-handling.md for the cascade rules.

# AWS_SECRET_NAME=/mmc/cts/kb-assistant
# AWS_REGION=us-east-1

# ─────────────────────────────────────────────────────────────
# Telemetry & measurement (Phase 6)
# ─────────────────────────────────────────────────────────────

# Application Insights connection string. Absent = OTel bootstrap logs a
# graceful-fallback notice and does NOT throw. Production value comes from
# AWS Secrets Manager.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Salt for the question-hash (SHA-256/16-hex). Production value is rotated
# annually and documented in docs/measurement-plan.md. In dev, absent-or-empty
# is tolerated — questionHash() returns a deterministic hash with no salt.
# QUESTION_HASH_SALT=<from-AWS-Secrets-Manager>

# ─────────────────────────────────────────────────────────────
# Eval LLM judge (optional — only needed to run `pnpm eval:slow`)
# ─────────────────────────────────────────────────────────────
#
# When absent, `pnpm eval:slow` skips cleanly. CI nightly cron provides these
# via GitHub Actions secrets.

# LLM_JUDGE_API_KEY=sk-...
# LLM_JUDGE_BASE_URL=https://api.openai.com/v1
