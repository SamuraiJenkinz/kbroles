# .env.production.example — KB Assistant on-prem Windows deploy template
#
# TEMPLATE ONLY. The real file lives on the Windows box at:
#   D:\kbroles\.env.production
# (one level ABOVE D:\kbroles\.next\standalone\)
#
# WHY that path: every GHA redeploy wipes D:\kbroles\.next\standalone\ (see
# docs/deploy-windows.md Step 7). Placing the env file one level above lets it
# survive redeploys without any operator action after the first setup.
#
# USAGE:
#   1. Copy this file to D:\kbroles\.env.production on the Windows box.
#   2. Fill in every blank value (secrets especially).
#   3. Lock down ACL (run as admin):
#        icacls D:\kbroles\.env.production /inheritance:r /grant:r "<svcAcct>:R"
#      Replace <svcAcct> with the service account that runs the Node process.
#   4. Launch the app via scripts/start.ps1 (see docs/deploy-windows.md Step 4.2 (alternative)).
#
# NODE_EXTRA_CA_CERTS is intentionally NOT in this template.
#   Node reads NODE_EXTRA_CA_CERTS at TLS init, BEFORE any .env loader runs
#   (see docs/env-handling.md §3 and nodejs/node#51426). It MUST remain a
#   machine-scope env var set via:
#     [System.Environment]::SetEnvironmentVariable('NODE_EXTRA_CA_CERTS', '...', 'Machine')
#
# AWS_SECRET_NAME is intentionally NOT in this template.
#   Its ABSENCE is what triggers the env-file-on-disk path in
#   src/config/secrets.ts — loadSecrets() short-circuits to process.env when
#   AWS_SECRET_NAME is unset. If you ever want to switch back to the AWS path,
#   set AWS_SECRET_NAME as a machine-scope env var (docs/deploy-windows.md Step 4.2).

# === Runtime (non-secret) ===
NODE_ENV=production
PORT=3001
HOSTNAME=127.0.0.1
APP_BASE_URL=https://kbassistant.example.mmc.com
LLM_AUTH_MODE=
LLM_MODEL=
CONTENT_STEWARD_EMAIL=

# === Secrets (11 keys — mirror SECRET_KEYS in src/config/secrets.ts lines 27-39) ===
SESSION_SECRET=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
LLM_API_KEY=
LLM_BASE_URL=
APPLICATIONINSIGHTS_CONNECTION_STRING=
QUESTION_HASH_SALT=
SERVICENOW_SERVICE_ACCOUNT=
SN_INSTANCE=
TEAMS_WEBHOOK_URL=
